{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "command": [
        "C:\\Users\\guini\\bin\\engram.exe",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:OPENCODE_POSTGRES_URL}"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@cyanheads/git-mcp-server@latest"
      ],
      "environment": {
        "PATH": "C:\\ProgramData\\chocolatey\\bin;C:\\Program Files\\Git\\cmd;C:\\WINDOWS\\System32"
      },
      "enabled": true
    }
  }
}
