{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:OPENCODE_POSTGRES_URL}"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@cyanheads/git-mcp-server@latest"
      ],
      // TODO: workaround temporal — se elimino el bloque environment con {env:PATH} por el mismo
      // bug de expansion de backslashes. Evaluar si es necesario restaurarlo cuando PR #14987 sea released.
      "enabled": true
    }
  }
}
